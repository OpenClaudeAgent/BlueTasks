# --- Dépendances ---
node_modules/

# --- Builds (Vite, tsc) ---
dist/
web/app/dist/
server/dist/
*.tsbuildinfo
.vite/

# --- Tests & couverture ---
coverage/
**/coverage/
coverage-gate/
**/coverage-gate/
playwright-report/
jscpd-report/
test-results/
playwright/.cache/

# --- Environnement & secrets (ne jamais committer) ---
.env
.env.*
!.env.example

# --- Données SQLite locales (dev / Docker volume) ---
.data/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS ---
.DS_Store
Thumbs.db

# --- IDE (garde les presets partageables si tu en ajoutes) ---
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Linters / caches ---
.eslintcache

# --- Outils locaux (MCP RPG, etc.) ---
.rpg/

# Docker build context (generated by scripts/assemble-docker-context.sh)
.dockerctx/

# Isolated npm context for the Tauri desktop runtime
.desktopctx/

# Generated Tauri bundle resources (embedded Node + app runtime)
desktop/src-tauri/resources/bluetasks-runtime/
desktop/src-tauri/resources/node/

# Rust / Tauri build output (see also desktop/src-tauri/.gitignore)
desktop/src-tauri/target/

# Regenerated from desktop/src-tauri/icons/bluetasks-icon.svg via `tauri icon`
desktop/src-tauri/icons/android/
desktop/src-tauri/icons/ios/
