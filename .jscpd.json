{
  "threshold": 0.65,
  "minLines": 10,
  "minTokens": 80,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.dockerctx/**",
    "**/.github/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/package-lock.json",
    "**/.git/**",
    "**/desktop/src-tauri/target/**"
  ],
  "reporters": ["console", "html"],
  "output": "./jscpd-report",
  "absolute": true
}
