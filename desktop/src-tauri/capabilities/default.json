{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window loads the local Express server over HTTP.",
  "windows": ["main"],
  "permissions": [
    "core:default"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:8787",
      "http://127.0.0.1:8787/*",
      "http://localhost:8787",
      "http://localhost:8787/*"
    ]
  }
}
