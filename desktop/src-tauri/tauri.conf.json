{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlueTasks",
  "mainBinaryName": "BlueTasks",
  "version": "0.3.0",
  "identifier": "com.bluetasks.app",
  "build": {
    "beforeBuildCommand": "npm run prep",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "BlueTasks",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "url": "http://127.0.0.1:8787"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/bluetasks-runtime/**/*",
      "resources/node/**/*"
    ]
  }
}
